    "browserRequirements": "Requires JavaScript. Requires HTML5.",
    "description": "Free online text-to-speech converter with 300+ natural AI voices, 50+ languages, MP3 download. No signup, no watermark.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "featureList": ["300+ AI voices", "50+ languages", "MP3 download", "No signup", "No watermark", "Privacy-first"],
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "127", "bestRating": "5" }
  }
